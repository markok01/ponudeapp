# PDF Converter Service
API_KEY=
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Limits
MAX_PDF_SIZE_MB=50
JOB_TTL_SECONDS=3600
CONVERSION_TIMEOUT_SECONDS=300

# OCR for scanned PDFs (requires poppler + paddle)
OCR_ENABLED=true
OCR_LANG=en

# Retry
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1.5

# Temp storage
TEMP_DIR=/tmp/pdf-converter
