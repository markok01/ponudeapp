# Kopiraj u .env.local i nalepi Aiven lozinku u MYSQL_PASSWORD
MYSQL_PASSWORD=your_aiven_password_here

MYSQL_HOST=mysql-75b205f-personalb.c.aivencloud.com
MYSQL_PORT=28711
MYSQL_USER=avnadmin
MYSQL_DATABASE=ponudaapp
MYSQL_SSL=true
MYSQL_SSL_REJECT_UNAUTHORIZED=false
# MYSQL_SSL_CA=... (opciono; inače se koristi ugrađeni CA iz lib/aiven-ca.ts)

# Ime firme u PDF headeru (opciono)
# NEXT_PUBLIC_COMPANY_NAME=Moja Firma d.o.o.

JWT_SECRET=generate-a-random-uuid-here

# Obavezna prijava (produkcija) — email + lozinka iz whitelist tabele users
AUTH_REQUIRED=true
# Maksimalan broj naloga (podrazumevano 2 — ti + jedna koleginica)
MAX_USERS=2

# Trajanje sesije (dani): „Zapamti me“ = dugo, inače kraće
SESSION_REMEMBER_DAYS=365
SESSION_DAYS=7

# ZASTARELO: jedna zajednička lozinka — koristite users tabelu umesto ovoga
# APP_PASSWORD=

MYSQL_CONNECTION_LIMIT=10
MYSQL_MAX_IDLE=5
MYSQL_IDLE_TIMEOUT_MS=30000

# PDF → Excel converter (Python FastAPI microservice)
PDF_CONVERTER_URL=http://localhost:8000
PDF_CONVERTER_API_KEY=
PDF_CONVERTER_TIMEOUT_MS=300000
